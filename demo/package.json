    "expo": "^57.0.7",
    "expo-constants": "~57.0.6",
    "expo-font": "~57.0.1",
    "expo-linking": "~57.0.3",
    "expo-router": "~57.0.7",
    "expo-status-bar": "~57.0.1",
    "msgpackr": "^1.11.5",
