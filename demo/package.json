{
  "name": "demo",
  "version": "1.0.0",
  "main": "expo/AppEntry.js",
  "type": "commonjs",
  "scripts": {
    "link": "npm link file:../react-native-short-style-devtools --legacy-peer-deps",
    "linkS": "cd ../styled && npm run buildThis && npm run assets && npm pack && cd ../demo && npm install ../styled/react-native-short-style-1.3.7.tgz",
    "export": "rmdir /s /q dist && expo export",
    "start": "npm run link && npm run linkS && expo start -c",
    "android": "npm run link && npm run linkS && expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d build",
    "build": "react-scripts build",
    "connect": "adb connect 127.0.0.1:58526"
  },
  "files": [
    "public",
    "./"
  ],
