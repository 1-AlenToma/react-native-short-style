{
  "name": "react-native-short-style",
  "version": "1.3.3",
  "description": "#react-native-short-style",
  "author": "1-AlenToma",
  "license": "MIT",
  "type": "commonjs",
  "repository": "https://github.com/1-AlenToma/react-native-short-style",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./mems": {
      "types": "./dist/mems.d.ts",
      "default": "./dist/mems.js"
    },
    "./babel-style-transformer": "./dist/babel-style-transformer.js"
  },
  "engines": {
    "node": ">=10"
  },
  "keywords": [
    "css in js",
    "css3",
    "css in react-native",
    "react-native css"
  ],
  "scripts": {
    "clean": "rmdir /s /q dist",
    "buildThis": "npm run clean && tsc && npm run assets && tsx scripts/transform-dist.ts",
    "build": "npm run buildThis && cd ../demo && npm run export",
    "assets": "cpx \"src/assets/**/*\" dist/src/assets",
    "ready": "npm run build",
    "web": "cd ../demo && npx expo start",
    "test": "tsc  && jest tsx ./dist/test/Methods.test.js",
    "beta": "npm publish --tag beta"
  },
  "peerDependencies": {
    "react": "*",
    "react-native": "*"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@babel/generator": "^8.0.0",
    "@babel/parser": "^8.0.4",
    "@types/node": "^26.1.1",
    "@types/react": "*",
    "@types/react-native": "*",
    "cpx": "*",
    "tsx": "^4.23.1",
    "typescript": "*"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@miblanchard/react-native-slider": "*",
    "css-to-react-native": "^3.2.0",
    "msgpackr": "*",
    "react-native-short-style-devtools": "*",
    "react-smart-state": "^1.1.5"
  }
}
